# ── Database
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/ravenbase

# ── Redis
REDIS_URL=redis://localhost:6379

# ── Auth (Clerk)
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
CLERK_FRONTEND_API=your-app.clerk.accounts.dev

# ── AI
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ── Vector Store (Qdrant)
QDRANT_URL=https://YOUR_CLUSTER.cloud.qdrant.io
QDRANT_API_KEY=...

# ── Graph Database (Neo4j AuraDB)
NEO4J_URI=neo4j+s://YOUR_INSTANCE.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=...

# ── File Storage (Supabase)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
STORAGE_BUCKET=ravenbase-sources

# ── Payments (Stripe)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_test_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_test_...
STRIPE_TEAM_MONTHLY_PRICE_ID=price_test_...
STRIPE_TEAM_ANNUAL_PRICE_ID=price_test_...
APP_BASE_URL=http://localhost:3000

# ── Email (Resend)
RESEND_API_KEY=re_test_...
RESEND_WEBHOOK_SECRET=whsec_...

# ── Security
CLOUDFLARE_ORIGIN_SECRET=changeme-replace-with-32-char-hex

# ── Config
APP_ENV=development
ENABLE_PII_MASKING=false
CONFLICT_SIMILARITY_THRESHOLD=0.87
MAX_CONCURRENT_INGEST_JOBS=3
MAX_DAILY_LLM_SPEND_USD=50.0
ADMIN_USER_IDS=user_xxx
